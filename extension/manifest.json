{
  "manifest_version": 3,
  "name": "Live Match Impact",
  "description": "Instant understanding of what a goal means.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "scripting", "notifications"],
  "host_permissions": ["<all_urls>", "http://localhost:3000/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
