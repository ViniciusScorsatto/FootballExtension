{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public-config.json",
  "title": "PublicConfig",
  "type": "object",
  "required": ["analytics", "billingReadiness", "build"],
  "properties": {
    "build": {
      "type": "object",
      "required": ["commitSha", "branch", "deploymentId", "nodeEnv"],
      "properties": {
        "commitSha": { "type": "string" },
        "branch": { "type": "string" },
        "deploymentId": { "type": "string" },
        "nodeEnv": { "type": "string" }
      },
      "additionalProperties": true
    },
    "billingReadiness": {
      "type": "object",
      "required": ["betaModeEnabled", "stripe"],
      "properties": {
        "betaModeEnabled": { "type": "boolean" },
        "stripe": {
          "type": "object",
          "required": [
            "enabled",
            "pricesConfigured",
            "successUrlConfigured",
            "cancelUrlConfigured"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "pricesConfigured": { "type": "boolean" },
            "successUrlConfigured": { "type": "boolean" },
            "cancelUrlConfigured": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "analytics": {
      "type": "object",
      "required": ["posthog"],
      "properties": {
        "posthog": {
          "type": "object",
          "required": ["enabled", "host", "apiKey"],
          "properties": {
            "enabled": { "type": "boolean" },
            "host": { "type": "string" },
            "apiKey": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
