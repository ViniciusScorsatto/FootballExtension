{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public-config.json",
  "title": "PublicConfig",
  "type": "object",
  "required": ["analytics"],
  "properties": {
    "analytics": {
      "type": "object",
      "required": ["posthog"],
      "properties": {
        "posthog": {
          "type": "object",
          "required": ["enabled", "host", "apiKey"],
          "properties": {
            "enabled": { "type": "boolean" },
            "host": { "type": "string" },
            "apiKey": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
